{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/duplicate_reads.py"
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/retry_loop.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/compaction_reset.py"
          }
        ]
      }
    ]
  }
}
